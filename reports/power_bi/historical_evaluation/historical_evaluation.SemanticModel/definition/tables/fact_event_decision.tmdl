	column 'predicted_severe_delay_probability (bins)' =
			IF(
				ISBLANK('fact_event_decision'[predicted_severe_delay_probability]),
				BLANK(),
				IF(
					'fact_event_decision'[predicted_severe_delay_probability] >= 0,
					ROUNDDOWN('fact_event_decision'[predicted_severe_delay_probability] / 0.05, 0) * 0.05,
					ROUNDUP('fact_event_decision'[predicted_severe_delay_probability] / 0.05, 0) * 0.05
				)
			)
		lineageTag: f339c798-a5b3-4c04-bf37-6b81f4f3ff34
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "fact_event_decision"
				          }
				        },
				        "Property": "predicted_severe_delay_probability"
				      }
				    }
				  ],
				  "binningMetadata": {
				    "binSize": {
				      "value": 0.05,
				      "unit": 0
				    }
				  }
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"f","Entity":"fact_event_decision"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"f"}},"Property":"predicted_severe_delay_probability"}}],"BinItem":{"Expression":{"Floor":{"Expression":{"Column":{"Expression":{"SourceRef":{"Source":"f"}},"Property":"predicted_severe_delay_probability"}},"Size":0.05}}}}

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Review Eligibility' = IF ( fact_event_decision[is_eligible_candidate], "Can be reviewed", "Not reviewable" )
		dataType: string
		lineageTag: 619fba29-8645-4ff3-853b-fbe7ea8a66e6
		summarizeBy: none

	column 'Review Decision' = SWITCH ( TRUE (), NOT fact_event_decision[is_eligible_candidate], "Not reviewable", fact_event_decision[selected_for_review], "Chosen for review", "Not chosen for review" )
		dataType: string
		lineageTag: 19e0c3d8-4cdd-4a70-bfb9-63dec06c7cba
		summarizeBy: none

	column 'Actual Outcome' = SWITCH ( TRUE (), ISBLANK ( fact_event_decision[actual_is_departure_severe_delay] ), "Outcome unavailable", fact_event_decision[actual_is_departure_severe_delay], "Became severe", "Did not become severe" )
		dataType: string
		lineageTag: 217e9d9d-0d95-4c7f-b88f-f47415f0a4bb
		summarizeBy: none

	column 'Predicted Risk Band' = VAR p = fact_event_decision[predicted_severe_delay_probability] RETURN SWITCH ( TRUE (), ISBLANK ( p ), "Unknown", p < 0.10, "00-10%", p < 0.20, "10-20%", p < 0.30, "20-30%", p < 0.40, "30-40%", p < 0.50, "40-50%", p < 0.60, "50-60%", p < 0.70, "60-70%", p < 0.80, "70-80%", p < 0.90, "80-90%", "90-100%" )
		dataType: string
		lineageTag: c0dc7539-8822-400e-ba17-cd11192dfe6f
		summarizeBy: none
		sortByColumn: 'Predicted Risk Band Sort'

	column 'Predicted Risk Band Sort' = VAR p = fact_event_decision[predicted_severe_delay_probability] RETURN IF ( ISBLANK ( p ), 99, MIN ( 10, INT ( p * 10 ) + 1 ) )
		dataType: int64
		lineageTag: d254ad51-437e-4af3-81e3-1f537ab0903e
		summarizeBy: none

